{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "flux": {
    "enabled": true
  },
  "kubernetes": {
    "fileMatch": [
      "apps/.+\\.yaml$",
      "infrastructure/.+\\.yaml$"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["helmv3", "flux"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false,
      "labels": ["dependencies", "helm"]
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false,
      "labels": ["dependencies", "ci"]
    }
  ]
}
